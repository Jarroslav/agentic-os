{
  "_doc": [
    "Policy for tests/lib/check-neutrality.py — the mechanical guarantee that no",
    "PII, personal names, or organization names ship in this repo.",
    "",
    "Layer 1 (`patterns`): cleartext regex classes that are safe to publish —",
    "each names a *shape* (an email, a home-directory path, a confidentiality",
    "marker, a vendor model ID), never a banned value. `allow` entries are",
    "regexes tested against the matched text; `allow_files` are repo-relative",
    "paths where the class is permitted (e.g. an eval-runner model pin).",
    "",
    "Layer 2 (`banned_token_hashes`): SHA-256 of case-normalized banned tokens,",
    "so the banned names themselves never appear here in cleartext. To add one:",
    "  python3 -c \"import hashlib;print(hashlib.sha256(b'<lowercase token>').hexdigest())\"",
    "Multi-word phrases are hashed as the words joined by single spaces and",
    "carry their word count in `words`.",
    "",
    "`layer1_exempt_paths` exists because this file must spell out the",
    "confidentiality-marker phrases to detect them; it stays subject to Layer 2."
  ],
  "patterns": {
    "email": {
      "regex": "[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}",
      "allow": [
        "@example\\.(com|org|net)$",
        "@users\\.noreply\\.github\\.com$",
        "^noreply@"
      ],
      "allow_files": []
    },
    "home_path": {
      "regex": "/(?:Users|home)/[A-Za-z][A-Za-z0-9_.-]{2,}",
      "allow": [
        "^/home/(?:runner|user|node|app|ci)$"
      ],
      "allow_files": []
    },
    "confidentiality_marker": {
      "regex": "(?i)proprietary\\s*(?:&|and)\\s*confidential|internal\\s+use\\s+only|company\\s+confidential",
      "allow": [],
      "allow_files": []
    },
    "vendor_model_id": {
      "regex": "(?i)(?<![a-z0-9])(?:claude-(?:opus|sonnet|haiku|fable|[0-9])[a-z0-9.-]*|gpt-[0-9][a-z0-9.-]*|gemini-[0-9][a-z0-9.-]*|us\\.anthropic\\.[a-z0-9.:_-]+)",
      "allow": [],
      "allow_files": [
        "plugins/agentic-sdlc/evals/plugin-eval-benchmark.json"
      ]
    }
  },
