}

_test_task_complete_is_silent() {
    local d; d=$(write_task "feat-a" "maintenance")
    touch "$d/technical-analysis.md" "$d/complexity-assessment.md" "$d/spec.md" "$d/plan.md" "$d/qa-checklist.md" "$d/qa-test-review.md" "$d/qa-report.md"
    emit_decision "$d/decisions.jsonl" "spec.approved" "approve"
    emit_decision "$d/decisions.jsonl" "plan.approved" "approve"
    emit_decision "$d/decisions.jsonl" "code-review.final" "approve"
    local out; out=$(printf '%s' "$POST_STDIN" | bash "$HOOK" 2>&1 || true)
    assert_silent "task handed off (phase=maintenance) — silent exit" "$out"
}

_test_light_flow_defaults_to_task_labeling_when_flow_absent() {
    write_task "feat-a" "main" >/dev/null   # no flow field
    local out; out=$(printf '%s' "$POST_STDIN" | bash "$HOOK" 2>&1 || true)
    assert_context_contains "no flow field — defaults to sdlc-task labeling" "sdlc-task Stage 1" "$out"
}

