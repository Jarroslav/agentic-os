    write_run 12 >/dev/null
    local out; out=$(printf '%s' "$POST_STDIN" | bash "$HOOK" 2>&1 || true)
    assert_silent "pipeline handoff (phase 12) — silent exit" "$out"
}

_test_pipeline_only_fires_when_status_running() {
    local run_dir="docs/superpowers/runs/20260714-1200-test"
    mkdir -p "$run_dir"
    cat > "$run_dir/meta.json" <<'EOF'
{"run_id":"20260714-1200-test","status":"completed","current_phase":5}
EOF
    local out; out=$(printf '%s' "$POST_STDIN" | bash "$HOOK" 2>&1 || true)
    assert_silent "completed pipeline run — silent exit" "$out"
}

_test_task_takes_priority_over_run() {
    write_task "feat-a" "main" >/dev/null
    write_run 7 >/dev/null
    local out; out=$(printf '%s' "$POST_STDIN" | bash "$HOOK" 2>&1 || true)
    assert_context_contains "active task takes priority over a run dir" "sdlc-task Stage 1" "$out"
}

_test_missing_decisions_file_treated_as_no_gate() {
    local d; d=$(write_task "feat-a" "main")
    touch "$d/technical-analysis.md" "$d/complexity-assessment.md" "$d/spec.md"
    # no decisions.jsonl at all
    local out; out=$(printf '%s' "$POST_STDIN" | bash "$HOOK" 2>&1 || true)
    assert_context_contains "missing decisions.jsonl — treated as gate not approved" "spec.approved not recorded" "$out"
}

# ----- runner -----

run_test() {
    local name="$1"
    printf '\n--- %s ---\n' "$name"
    with_tmpdir "$name"
}

TESTS="_test_no_active_run _test_non_posttooluse_event_is_noop _test_task_stage1 _test_task_stage2 _test_task_stage3_writing _test_task_stage3_gate_pending _test_task_stage4_writing _test_task_stage4_gate_pending _test_task_stage5 _test_task_stage6 _test_task_stage6_impl_completion_advances_to_stage7 _test_task_stage7 _test_task_stage8_unresolved _test_task_stage8_resolved_via_checkround _test_task_stage9 _test_task_stage10_11 _test_task_complete_is_silent _test_light_flow_defaults_to_task_labeling_when_flow_absent _test_light_stage1 _test_light_stage2_3 _test_light_stage3_gate_pending _test_light_stage4_with_qa_foundation _test_light_stage4_skipped_without_qa_foundation _test_light_stage5_with_qa_foundation _test_light_stage5_impl_completion_advances_to_stage6 _test_light_stage6_with_qa_foundation _test_light_stage7_unresolved _test_light_stage8 _test_light_stage9_10_with_qa_foundation _test_light_stage10_without_qa_foundation _test_light_complete_is_silent _test_pipeline_phase1 _test_pipeline_phase4_gate_pending _test_pipeline_phase4_in_progress_no_design_yet _test_pipeline_phase5_gate_pending _test_pipeline_phase7 _test_pipeline_phase11 _test_pipeline_phase12_is_silent _test_pipeline_only_fires_when_status_running _test_task_takes_priority_over_run _test_missing_decisions_file_treated_as_no_gate"

for t in $TESTS; do
    run_test "$t"
done

printf '\n=== %d passed, %d failed ===\n' "$PASS" "$FAIL"
[ "$FAIL" -eq 0 ] || exit 1
