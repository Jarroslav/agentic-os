_test_pipeline_phase1() {
    write_run 1 >/dev/null
    local out; out=$(printf '%s' "$POST_STDIN" | bash "$HOOK" 2>&1 || true)
    assert_context_contains "pipeline phase 1 — nudges requirements-intake" "Phase 1" "$out"
}

_test_pipeline_phase4_gate_pending() {
    local d; d=$(write_run 4)
    touch "$d/design.md"
    local out; out=$(printf '%s' "$POST_STDIN" | bash "$HOOK" 2>&1 || true)
    assert_context_contains "pipeline phase 4 gate pending — spec.approved missing" "spec.approved not recorded" "$out"
}

_test_pipeline_phase4_in_progress_no_design_yet() {
    write_run 4 >/dev/null
    local out; out=$(printf '%s' "$POST_STDIN" | bash "$HOOK" 2>&1 || true)
    assert_context_contains "pipeline phase 4 in progress — no design.md yet" "Phase 4 in progress" "$out"
}

