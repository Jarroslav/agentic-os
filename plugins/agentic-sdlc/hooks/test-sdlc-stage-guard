#!/usr/bin/env bash
# Tests for sdlc-stage-guard (PostToolUse(Skill) hook).
# Run from repo root: bash plugins/agentic-sdlc/hooks/test-sdlc-stage-guard
#
# Every scenario runs inside a fresh mktemp -d sandbox (nothing touches the
# working repo). The hook is informational-only: every assertion here checks
# the emitted additionalContext string, never a block/deny decision — this
# hook has no PreToolUse or Stop wiring to test.
set -uo pipefail

HOOK="$( cd "$(dirname "$0")" && pwd )/sdlc-stage-guard"
PASS=0
FAIL=0

POST_STDIN='{"tool_name":"Skill","tool_input":{"skill":"some-skill"},"tool_response":{"result":"ok"}}'

# ----- fixtures -----

write_task() {
    # $1 = slug, $2 = state phase ("main" or "maintenance"), $3 = flow (optional)
    local slug="$1" phase="${2:-main}" flow="${3:-}"
    local task_dir="docs/superpowers/tasks/2026-07-14-$slug"
    mkdir -p "$task_dir"
    if [ -n "$flow" ]; then
        cat > "$task_dir/.state.json" <<EOF
{"schema":1,"flow":"$flow","slug":"$slug","branch":"feat/$slug","phase":"$phase","started_at":"2026-07-14T00:00:00Z"}
EOF
    else
        cat > "$task_dir/.state.json" <<EOF
{"schema":1,"slug":"$slug","branch":"feat/$slug","phase":"$phase","started_at":"2026-07-14T00:00:00Z"}
EOF
    fi
    printf '%s' "$task_dir"
}

write_qa_foundation() {
    mkdir -p .agentic/guides/testing
    touch .agentic/guides/testing/qa-strategy.md
}

write_run() {
    # $1 = current_phase (integer)
    local phase="$1"
    local run_dir="docs/superpowers/runs/20260714-1200-test"
    mkdir -p "$run_dir"
    cat > "$run_dir/meta.json" <<EOF
{"run_id":"20260714-1200-test","status":"running","current_phase":$phase}
EOF
    printf '%s' "$run_dir"
}

emit_decision() {
    # $1 = decisions.jsonl path, $2 = gate_id, $3 = decision (approve|request-changes)
    printf '{"gate_id":"%s","verdict":{"decision":"%s"}}\n' "$2" "$3" >> "$1"
}

# ----- assertion helpers -----

assert_context_contains() {
    # $1 = label, $2 = needle, $3 = full hook output
    if printf '%s' "$3" | grep -qF "$2"; then
        printf 'PASS: %s\n' "$1"; PASS=$((PASS+1))
    else
        printf 'FAIL: %s (expected to find %q in: %s)\n' "$1" "$2" "$3"; FAIL=$((FAIL+1))
    fi
}

assert_silent() {
    # $1 = label, $2 = full hook output
    if [ -z "$2" ]; then
        printf 'PASS: %s\n' "$1"; PASS=$((PASS+1))
    else
        printf 'FAIL: %s (expected silence, got: %s)\n' "$1" "$2"; FAIL=$((FAIL+1))
    fi
}

with_tmpdir() {
    local name="$1"
    local orig; orig="$PWD"
    local tmp; tmp=$(mktemp -d 2>/dev/null || mktemp -d -t stage-guard-test)
    cd "$tmp" || return 1
    "$name"
    cd "$orig" || true
    rm -rf "$tmp"
}

# ----- test scenarios -----

_test_no_active_run() {
    local out; out=$(printf '%s' "$POST_STDIN" | bash "$HOOK" 2>&1 || true)
    assert_silent "no active run — silent exit" "$out"
}

_test_non_posttooluse_event_is_noop() {
    write_task "x" "main" >/dev/null
    local out; out=$(printf '{"session_id":"s1"}' | bash "$HOOK" 2>&1 || true)
    assert_silent "non-PostToolUse payload — silent exit" "$out"
}

_test_task_stage1() {
    write_task "feat-a" "main" >/dev/null
    local out; out=$(printf '%s' "$POST_STDIN" | bash "$HOOK" 2>&1 || true)
    assert_context_contains "stage 1 — nudges codebase-scout" "Stage 1" "$out"
    assert_context_contains "stage 1 — names the slug" "feat-a" "$out"
}

_test_task_stage2() {
    local d; d=$(write_task "feat-a" "main")
    touch "$d/technical-analysis.md"
    local out; out=$(printf '%s' "$POST_STDIN" | bash "$HOOK" 2>&1 || true)
    assert_context_contains "stage 2 — nudges sizing-analyst" "Stage 2" "$out"
}

_test_task_stage3_writing() {
    local d; d=$(write_task "feat-a" "main")
    touch "$d/technical-analysis.md" "$d/complexity-assessment.md"
    local out; out=$(printf '%s' "$POST_STDIN" | bash "$HOOK" 2>&1 || true)
    assert_context_contains "stage 3 — nudges brainstorm/spec" "Stage 3" "$out"
}

_test_task_stage3_gate_pending() {
    local d; d=$(write_task "feat-a" "main")
    touch "$d/technical-analysis.md" "$d/complexity-assessment.md" "$d/spec.md"
    local out; out=$(printf '%s' "$POST_STDIN" | bash "$HOOK" 2>&1 || true)
    assert_context_contains "stage 3 gate pending — spec.approved missing" "spec.approved not recorded" "$out"
}

_test_task_stage4_writing() {
    local d; d=$(write_task "feat-a" "main")
    touch "$d/technical-analysis.md" "$d/complexity-assessment.md" "$d/spec.md"
    emit_decision "$d/decisions.jsonl" "spec.approved" "approve"
    local out; out=$(printf '%s' "$POST_STDIN" | bash "$HOOK" 2>&1 || true)
    assert_context_contains "stage 4 — nudges writing-plans" "Stage 4" "$out"
    assert_context_contains "stage 4 — no false gate-pending" "Execution Handoff" "$out"
}

_test_task_stage4_gate_pending() {
    local d; d=$(write_task "feat-a" "main")
    touch "$d/technical-analysis.md" "$d/complexity-assessment.md" "$d/spec.md" "$d/plan.md"
    emit_decision "$d/decisions.jsonl" "spec.approved" "approve"
    local out; out=$(printf '%s' "$POST_STDIN" | bash "$HOOK" 2>&1 || true)
    assert_context_contains "stage 4 gate pending — plan.approved missing" "plan.approved not recorded" "$out"
}

_test_task_stage5() {
    local d; d=$(write_task "feat-a" "main")
    touch "$d/technical-analysis.md" "$d/complexity-assessment.md" "$d/spec.md" "$d/plan.md"
    emit_decision "$d/decisions.jsonl" "spec.approved" "approve"
    emit_decision "$d/decisions.jsonl" "plan.approved" "approve"
    local out; out=$(printf '%s' "$POST_STDIN" | bash "$HOOK" 2>&1 || true)
    assert_context_contains "stage 5 — nudges qa-planner --checklist" "Stage 5" "$out"
}

_test_task_stage6() {
    local d; d=$(write_task "feat-a" "main")
    touch "$d/technical-analysis.md" "$d/complexity-assessment.md" "$d/spec.md" "$d/plan.md" "$d/qa-checklist.md"
    emit_decision "$d/decisions.jsonl" "spec.approved" "approve"
    emit_decision "$d/decisions.jsonl" "plan.approved" "approve"
    local out; out=$(printf '%s' "$POST_STDIN" | bash "$HOOK" 2>&1 || true)
    assert_context_contains "stage 6 — nudges inline TDD" "Stage 6" "$out"
}

_test_task_stage6_impl_completion_advances_to_stage7() {
    local d; d=$(write_task "feat-a" "main")
    touch "$d/technical-analysis.md" "$d/complexity-assessment.md" "$d/spec.md" "$d/plan.md" "$d/qa-checklist.md"
    emit_decision "$d/decisions.jsonl" "spec.approved" "approve"
    emit_decision "$d/decisions.jsonl" "plan.approved" "approve"
    local stdin='{"tool_name":"Skill","tool_input":{"skill":"superpowers:test-driven-development"},"tool_response":{"result":"ok"}}'
    local out; out=$(printf '%s' "$stdin" | bash "$HOOK" 2>&1 || true)
    assert_context_contains "stage 6 impl-just-completed — advances to stage 7, not re-nudged for stage 6" "Stage 7" "$out"
}

_test_task_stage7() {
    local d; d=$(write_task "feat-a" "main")
    touch "$d/technical-analysis.md" "$d/complexity-assessment.md" "$d/spec.md" "$d/plan.md" "$d/qa-checklist.md"
    emit_decision "$d/decisions.jsonl" "spec.approved" "approve"
    emit_decision "$d/decisions.jsonl" "plan.approved" "approve"
    # qa-test-review.md still absent; the qa-planner dispatch is the transition
    # signal (sdlc-task writes no evidence file for inline implementation).
    local stdin='{"tool_name":"Skill","tool_input":{"skill":"qa-planner"},"tool_response":{"result":"ok"}}'
    local out; out=$(printf '%s' "$stdin" | bash "$HOOK" 2>&1 || true)
    assert_context_contains "stage 7 — nudges qa-planner --review-tests" "Stage 7" "$out"
}

_test_task_stage8_unresolved() {
    local d; d=$(write_task "feat-a" "main")
    touch "$d/technical-analysis.md" "$d/complexity-assessment.md" "$d/spec.md" "$d/plan.md" "$d/qa-checklist.md" "$d/qa-test-review.md"
    emit_decision "$d/decisions.jsonl" "spec.approved" "approve"
    emit_decision "$d/decisions.jsonl" "plan.approved" "approve"
    local out; out=$(printf '%s' "$POST_STDIN" | bash "$HOOK" 2>&1 || true)
    assert_context_contains "stage 8 — code review unresolved" "Stage 8" "$out"
}

_test_task_stage8_resolved_via_checkround() {
    local d; d=$(write_task "feat-a" "main")
    touch "$d/technical-analysis.md" "$d/complexity-assessment.md" "$d/spec.md" "$d/plan.md" "$d/qa-checklist.md" "$d/qa-test-review.md"
    emit_decision "$d/decisions.jsonl" "spec.approved" "approve"
    emit_decision "$d/decisions.jsonl" "plan.approved" "approve"
    emit_decision "$d/decisions.jsonl" "code-review.final" "request-changes"
    emit_decision "$d/decisions.jsonl" "code-review.check" "approve"
    local out; out=$(printf '%s' "$POST_STDIN" | bash "$HOOK" 2>&1 || true)
    assert_context_contains "stage 8 resolved via check round — advances to stage 9" "Stage 9" "$out"
}

_test_task_stage9() {
    local d; d=$(write_task "feat-a" "main")
    touch "$d/technical-analysis.md" "$d/complexity-assessment.md" "$d/spec.md" "$d/plan.md" "$d/qa-checklist.md" "$d/qa-test-review.md"
