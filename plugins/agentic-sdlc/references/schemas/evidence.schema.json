{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase 7 task evidence (<run_dir>/evidence/<task-id>.json)",
  "type": "object",
  "required": [
    "schema",
    "task_id",
    "test_first",
    "failing_test_command",
    "failure_excerpt",
    "passing_command",
    "passing_excerpt",
    "files_touched"
  ],
  "properties": {
    "schema": {
      "const": 1
    },
    "task_id": {
      "type": "string"
    },
    "test_first": {
      "type": "boolean"
    },
    "failing_test_command": {
      "type": "string"
    },
    "failure_excerpt": {
      "type": "string",
      "maxLength": 2000
    },
    "implementation_summary": {
      "type": "string"
    },
    "passing_command": {
      "type": "string"
    },
    "passing_excerpt": {
      "type": "string",
      "maxLength": 2000
    },
    "files_touched": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "diff_lines_added": {
      "type": "integer",
      "minimum": 0
    },
    "diff_lines_removed": {
      "type": "integer",
      "minimum": 0
    }
  }
}
