{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase 3 complexity result (<run_dir>/complexity.json)",
  "type": "object",
  "required": [
    "score",
    "routing"
  ],
  "properties": {
    "score": {
      "type": "integer",
      "minimum": 6,
      "maximum": 36
    },
    "breakdown": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 1,
        "maximum": 6
      }
    },
    "routing": {
      "enum": [
        "writing-plans",
        "brainstorming",
        "split-required"
      ]
    },
    "rationale": {
      "type": "string"
    },
    "source": {
      "enum": [
        "heuristic",
        "agent"
      ]
    }
  }
}
