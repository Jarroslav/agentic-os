{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase 9 review bundle (<run_dir>/review-bundle.json)",
  "type": "object",
  "required": [
    "schema",
    "diff_base",
    "changed_files",
    "diffstat"
  ],
  "properties": {
    "schema": {
      "const": 1
    },
    "diff_base": {
      "type": "string"
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "diffstat": {
      "type": "object",
      "required": [
        "files",
        "added",
        "removed"
      ],
      "properties": {
        "files": {
          "type": "integer",
          "minimum": 0
        },
        "added": {
          "type": "integer",
          "minimum": 0
        },
        "removed": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_summaries": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "artifact_refs": {
      "type": "array"
    }
  }
}
