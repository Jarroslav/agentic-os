{
  "permissions": {
    "deny": [
      "Read(.env*)",
      "Read(.auth/**)",
      "Read(*token*.env)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/prompt_scan_guard.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/human_gated_commands.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/precommit_review_gate.py"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/guarded_write_paths.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/write_scope_guard.py block"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/guarded_write_paths.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/write_scope_guard.py block"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/migration_notice.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/instruction_stale_notice.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/lint_on_save.py"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/migration_notice.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/instruction_stale_notice.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/lint_on_save.py"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/context_monitor.py"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/instruction_gate.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/subagent_gate.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/session_learnings_notice.py"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/subagent_gate.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/session_start_bootstrap.py"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/precompact_checkpoint.py"
          }
        ]
      }
    ]
  }
}
