.DS_Store
*.pyc
__pycache__/
.agentic/
docs/superpowers/

# Local dev-session tooling artifacts (e.g. a pre-commit review-gate stamp) —
# never part of the shipped product.
.claude/
.serena/

# Local maintainer artifact for the originality check (tests/lib/check-provenance.py)
# — built locally, never committed.
tests/lib/provenance-fingerprints.json

# Build rationale, audit trails, and repo-administration notes live in a
# separate private repo, never here.
docs/DESIGN.md
docs/PLAN.md
docs/GITHUB-SETUP.md
docs/positioning-review.md
docs/audits/
docs/workstreams/
NOTES*.md
*.internal.md
mcp/dist/
node_modules/

# Copied from the repo root at build time (mcp/scripts/build-content.mjs) so
# the npm tarball carries Apache-2.0's required LICENSE + NOTICE — one source
# of truth at the root, not duplicated in git.
mcp/LICENSE
mcp/NOTICE
