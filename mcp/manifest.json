{
  "manifest_version": "0.3",
  "name": "agentic-os-mcp",
  "display_name": "agentic-os",
  "version": "0.1.0",
  "description": "Read-only MCP server for the agentic-os governance, SDLC, and QE methodology.",
  "author": { "name": "Yaroslav Krivushenko", "url": "https://github.com/Jarroslav" },
  "license": "Apache-2.0",
  "server": {
    "type": "node",
    "entry_point": "dist/index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/dist/index.js"]
    }
  }
}
