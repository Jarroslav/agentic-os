  "license": "Apache-2.0",
  "author": {
    "name": "Yaroslav Krivushenko",
    "url": "https://github.com/Jarroslav"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jarroslav/agentic-os.git",
    "directory": "mcp"
  },
  "homepage": "https://github.com/Jarroslav/agentic-os/tree/main/mcp#readme",
