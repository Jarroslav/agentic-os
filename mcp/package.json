{
  "name": "agentic-os-mcp",
  "version": "0.1.0",
  "description": "MCP server serving the agentic-os governance, SDLC, and QE methodology. Read-only.",
  "mcpName": "io.github.jarroslav/agentic-os",
  "license": "Apache-2.0",
  "author": { "name": "Yaroslav Krivushenko", "url": "https://github.com/Jarroslav" },
  "type": "module",
  "bin": { "agentic-os-mcp": "dist/index.js" },
  "files": ["dist", "content-index.json"],
  "engines": { "node": ">=20" },
  "scripts": {
    "build:content": "node scripts/build-content.mjs",
    "build:ts": "tsc -p tsconfig.json",
    "build": "npm run build:content && npm run build:ts",
    "check:drift": "node scripts/check-content-drift.mjs",
    "test": "vitest run",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
